# Your Discord bot token (Get this from the Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Your MailerSend API token
MAILERSEND_API_KEY=your_mailersend_api_key_here

# Your Airtable configuration (Optional)
AIRTABLE_PERSONAL_ACCESS_TOKEN=your_airtable_token_here

# Developer mode (set to true to test locally without affecting production servers)
DEVELOPER_MODE=false

# Secret token to authenticate incoming webhooks from Airtable
WEBHOOK_SECRET=your_webhook_secret_here
